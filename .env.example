# ===== Meta (Instagram orgánico + Facebook orgánico + Meta Ads) =====
# Token de larga duración o de System User con permisos:
#   read_insights, pages_read_engagement, instagram_basic, instagram_manage_insights, ads_read
META_ACCESS_TOKEN=

# IDs de Ebema (ya descubiertos):
META_AD_ACCOUNT_ID=823470930601959   # "NUEVA CUENTA EBEMA 2026" (con o sin act_)
META_PAGE_ID=102254444856912         # Página de Facebook "Ebema"
# Si la cuenta de IG no se resuelve sola desde la página, fíjala a mano:
# META_IG_USER_ID=

# Opcionales
# META_GRAPH_VERSION=v21.0
# SOCIAL_MONTHS=6                     # meses de historial a traer
# DASHBOARD_CACHE_MS=600000           # caché en memoria (10 min)

# ===== Google Ads (paid, API en vivo) =====
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=              # id de la cuenta Ebema, solo dígitos (sin guiones)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=     # id de la MCC, solo dígitos (si la cuenta cuelga de una MCC)
# OAuth (si no se definen, caen a GOOGLE_OAUTH_* de abajo). El refresh token necesita scope de Ads.
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_API_VERSION=v18

# ===== GA4 (Google Analytics) — mismas credenciales que el dashboard de Brevo =====
GA4_PROPERTY_ID=
# Opción A: OAuth de un usuario con acceso a GA
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# Opción B: cuenta de servicio con acceso de lectura en GA
# GA_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# ===== LinkedIn (Página de empresa, API en vivo) =====
# Token OAuth con scopes r_organization_social (+ rw_organization_admin). Ver README.
LINKEDIN_ACCESS_TOKEN=               # se genera cuando LinkedIn apruebe la Community Management API
LINKEDIN_ORG_ID=3863744              # Ebema (ya obtenido)
# LINKEDIN_VERSION=202401            # versión de la API, formato YYYYMM

# ===== Brevo (Email Marketing) =====
BREVO_API_KEY=
# MAX_PAGES=3                         # páginas de campañas de email a recorrer

# ===== Modo edición (versión interna con clave) =====
# Clave para entrar a /?edit y editar conclusiones + competencia.
EDIT_PASSWORD=
# Almacenamiento compartido para que lo editado lo vea el cliente (Vercel KV / Upstash).
# Se setean solos al agregar la integración "KV / Upstash" en el proyecto de Vercel.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ===== Protección opcional del link (HTTP Basic). Vacías = link ABIERTO =====
# DASHBOARD_USER=ebema
# DASHBOARD_PASSWORD=una_clave_segura
